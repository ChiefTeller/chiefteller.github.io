<script>
  document.addEventListener("DOMContentLoaded", function () {
    const gateway = document.querySelector("[data-home-gateway]");
    if (!gateway) return;

    const buttons = gateway.querySelectorAll("[data-home-target]");
    const panels = gateway.querySelectorAll("[data-home-panel]");

    buttons.forEach(function (button) {
      button.addEventListener("click", function () {
        const target = button.getAttribute("data-home-target");

        buttons.forEach(function (btn) {
          btn.classList.remove("active");
        });

        panels.forEach(function (panel) {
          panel.classList.remove("active");
        });

        button.classList.add("active");

        const activePanel = gateway.querySelector('[data-home-panel="' + target + '"]');
        if (activePanel) {
          activePanel.classList.add("active");
        }
      });
    });
  });
</script>
